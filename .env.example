# Komiko Configuration
# Copy this file to .env and edit as needed

# Secret key for sessions (generate a new one for production!)
SECRET_KEY=change-me-in-production

# Environment: development or production
FLASK_ENV=production

# Data directory (where database and covers are stored)
KOMIKO_DATA_DIR=./data

# Host and port
KOMIKO_HOST=0.0.0.0
KOMIKO_PORT=5000

# Database URL (only change if using external database)
# DATABASE_URL=sqlite:///data/komiko.db